# Supabase — anon key only (RLS is the security model; never the service-role key).
# Copy to .env and fill in from your Supabase project settings.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# OneSignal — PUBLIC app id only (safe to ship in the client bundle). The REST API
# key is a SECRET and must NEVER live here; it is a Supabase Edge Function env var.
EXPO_PUBLIC_ONESIGNAL_APP_ID=YOUR-ONESIGNAL-APP-ID

# ─────────────────────────────────────────────────────────────────────────────
# Edge Function secrets — DO NOT put these in .env / the client bundle. Set them
# with `supabase secrets set ...` (server-side only). Listed here for reference
# by the sunday-push-scheduler function (see supabase/functions/sunday-push-scheduler):
#   ONESIGNAL_APP_ID          OneSignal app id (server copy)
#   ONESIGNAL_REST_API_KEY    OneSignal REST API key (SECRET)
#   OPENAI_API_KEY            GPT-4o-mini hook generation (4+ items only)
#   POSTHOG_API_KEY           PostHog project key for delivery events
#   POSTHOG_HOST              e.g. https://us.i.posthog.com (optional; has a default)
#   SENTRY_DSN                Sentry DSN for OneSignal delivery failures
#   CRON_SECRET               shared secret the Upstash/QStash cron sends as x-cron-secret
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically by Supabase.
