# Supabase — anon key only (RLS is the security model; never the service-role key).
# Copy to .env and fill in from your Supabase project settings.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Edge Function secrets — server-side only (set via `supabase secrets set ...`),
# NEVER in .env / the client bundle:
#   OPENAI_API_KEY          GPT-4o-mini (panic-button, import-recipe) + Whisper
#   GOOGLE_VISION_API_KEY   receipt OCR (ocr-receipt)
# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY are injected automatically by Supabase.
